# Copy this to .env.local and fill in your values.
# .env.local is gitignored — never commit secrets.

# Local open-source default:
# 1. Install Ollama
# 2. Run: ollama pull qwen3:8b
# 3. Run: ollama serve
VITE_LLM_PROVIDER=ollama
VITE_LLM_BASE_URL=http://127.0.0.1:11434
VITE_LLM_MODEL=qwen3:8b

# For hosted/self-hosted OpenAI-compatible APIs:
# VITE_LLM_PROVIDER=openai-compatible
# VITE_LLM_BASE_URL=http://127.0.0.1:11434/v1
# VITE_LLM_MODEL=qwen3:8b
# VITE_LLM_API_KEY=

# For UI work without model calls:
# VITE_LLM_PROVIDER=mock

VITE_SITE_PASSWORD=your-password-here
